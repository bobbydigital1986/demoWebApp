{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://localhost:5000",
  "dependencies": {
    "@bugsnag/browser-performance": "^3.2.0",
    "@bugsnag/js": "^8.8.1",
    "@bugsnag/plugin-react": "^8.8.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build && npm run upload-sourcemaps",
    "build:no-upload": "react-scripts build",
    "upload-sourcemaps": "dotenv -e .env -- bash -c 'bugsnag-cli upload js --api-key=$REACT_APP_BUGSNAG_API_KEY --version-name=$REACT_APP_VERSION --base-url=http://*/static/js build/static/js --overwrite'",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@bugsnag/cli": "^3.7.0"
  }
}
