# Bugsnag Configuration
# Get your API key from: https://app.bugsnag.com/settings

# Required: Your Bugsnag API key
REACT_APP_BUGSNAG_API_KEY=YOUR-API-KEY

# Optional: App version for tracking releases
REACT_APP_VERSION=1.0.0

# Optional: Base URL for your deployed app (used for source map URL mapping)
PUBLIC_URL=http://localhost:3000
